{
	"name": "@lesjoursfr/html-to-pdf",
	"version": "4.1.0",
	"description": "A library to generate PDF from HTML.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lesjoursfr/html-to-pdf.git"
	},
	"homepage": "https://github.com/lesjoursfr/html-to-pdf#readme",
	"bugs": {
		"url": "https://github.com/lesjoursfr/html-to-pdf/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "22.x || 24.x"
	},
	"keywords": [
		"pdf",
		"generator",
		"html"
	],
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"scripts": {
		"freshlock": "rm -rf node_modules/ && rm .yarn/install-state.gz && rm yarn.lock && yarn",
		"check-lint": "eslint",
		"check-format": "prettier --check .",
		"check-tsc": "tsc --noEmit",
		"lint": "eslint --fix",
		"format": "prettier --write .",
		"build": "tsc && cp src/electron.js lib/electron.js",
		"test": "mocha"
	},
	"dependencies": {
		"electron": "^42.0.1",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@tsconfig/node22": "22.0.5",
		"@types/mocha": "10.0.10",
		"@types/node": "24.12.4",
		"@types/yargs": "17.0.35",
		"eslint": "10.3.0",
		"eslint-config-prettier": "10.1.8",
		"globals": "17.6.0",
		"mocha": "11.7.5",
		"prettier": "3.8.3",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.3"
	},
	"dependenciesMeta": {
		"electron": {
			"built": true
		}
	},
	"packageManager": "yarn@4.14.1"
}
